{
  "compilerOptions": {
    "target": "es2020",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "react"
  },
  "include": [
    "test/fixtures/consumer-types.fixture.ts",
    "test/fixtures/companion-types.fixture.ts",
    "models/ai.ts",
    "models/ai-agent-sse.ts",
    "models/companion.ts",
    "dtos/companion.ts"
  ]
}
