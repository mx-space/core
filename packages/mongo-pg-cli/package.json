{
  "name": "@mx-space/mongo-pg-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "One-shot Mongo → PostgreSQL data migration CLI for mx-space v11 → v12 upgrades",
  "license": "AGPLv3",
  "author": "Innei <https://innei.in>",
  "files": [
    "dist",
    "src"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "mx-mongo-pg-migrate": "./dist/cli.mjs"
  },
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/cli.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@mx-space/db-schema": "workspace:*",
    "drizzle-orm": "*",
    "mongodb": "*",
    "pg": "*"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "tsdown": "0.21.10",
    "tsx": "^4.21.0",
    "typescript": "6.0.3"
  }
}
