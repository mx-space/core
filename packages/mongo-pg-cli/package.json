{
  "name": "@mx-space/mongo-pg-cli",
  "version": "0.1.0",
  "description": "One-shot MongoDB → PostgreSQL data migration CLI for upgrading mx-space from v11 to v12",
  "keywords": [
    "mx-space",
    "migration",
    "mongodb",
    "postgresql",
    "drizzle",
    "cli"
  ],
  "homepage": "https://github.com/mx-space/core/tree/master/packages/mongo-pg-cli#readme",
  "bugs": {
    "url": "https://github.com/mx-space/core/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mx-space/core.git",
    "directory": "packages/mongo-pg-cli"
  },
  "license": "AGPL-3.0",
  "author": "Innei <https://innei.in>",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "mx-mongo-pg-migrate": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "package": "rm -rf dist && tsdown && cp -R ../../apps/core/src/database/migrations dist/migrations",
    "build": "npm run package",
    "prepackage": "rm -rf dist",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli.ts",
    "prepare": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "publish": "bump"
  },
  "bump": {
    "before": [
      "git pull --rebase",
      "pnpm i",
      "npm run package"
    ],
    "after": [
      "npm publish --access=public"
    ],
    "tag": false,
    "commit_message": "chore(release): bump @mx-space/mongo-pg-cli to v${NEW_VERSION}"
  },
  "devDependencies": {
    "@mx-space/db-schema": "workspace:*",
    "@types/pg": "^8.11.10",
    "drizzle-orm": "^0.45.0",
    "mongodb": "~7.2.0",
    "pg": "^8.13.1",
    "tsdown": "0.21.10",
    "tsx": "^4.21.0",
    "typescript": "6.0.3"
  }
}
