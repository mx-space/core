{
  "name": "@mx-space/db-schema",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Drizzle schema, EntityId, Snowflake generator and shared DB enums for mx-space",
  "license": "AGPLv3",
  "author": "Innei <https://innei.in>",
  "files": [
    "dist",
    "src"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "import": "./src/schema/index.ts"
    },
    "./id": {
      "types": "./src/id/index.ts",
      "import": "./src/id/index.ts"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./schema": {
        "types": "./dist/schema/index.d.ts",
        "import": "./dist/schema/index.js"
      },
      "./id": {
        "types": "./dist/id/index.d.ts",
        "import": "./dist/id/index.js"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260715.1",
    "@types/node": "26.1.1",
    "tsdown": "0.22.8",
    "typescript": "6.0.3"
  }
}
