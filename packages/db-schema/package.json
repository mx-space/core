{
  "name": "@mx-space/db-schema",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Drizzle schema, EntityId, Snowflake generator and shared DB enums for mx-space",
  "license": "AGPLv3",
  "author": "Innei <https://innei.in>",
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./id": {
      "types": "./dist/id/index.d.ts",
      "import": "./dist/id/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "prepare": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "*",
    "zod": "*"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "tsdown": "0.21.10",
    "typescript": "6.0.3"
  }
}
