{
  "name": "@mx-space/webhook",
  "version": "0.8.1",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.cts",
  "exports": {
    ".": {
      "types": {
        "require": "./dist/index.d.cts",
        "import": "./dist/index.d.mts"
      },
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    },
    "./dist/*": {
      "require": "./dist/*.cjs",
      "import": "./dist/*.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node scripts/extract-models.js && node scripts/generate.js && tsdown"
  },
  "devDependencies": {
    "express": "5.2.1",
    "tsdown": "0.21.7"
  },
  "bump": {
    "before": [
      "git pull --rebase",
      "pnpm i",
      "npm run build"
    ],
    "after": [
      "npm publish --access=public"
    ],
    "tag": false,
    "commit_message": "chore(release): bump @mx-space/webhook to v${NEW_VERSION}"
  }
}
