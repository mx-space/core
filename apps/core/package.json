  },
  "author": "Innei <https://innei.in>",
  "issues": "https://github.com/mx-space/core/issues",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "npm run bundle",
    "dev": "cross-env NODE_ENV=development nodemon --signal SIGKILL --watch src --ext ts,json --exec \"vite-node src/dev.ts\"",
    "dev:encrypt": "npm run dev -- --encrypt_enable --encrypt_key=33b9405ac49f63ef4ccbf6b338aeeff8152e844d942ef22278abbec2b1f93b5e",
    "migrate": "vite-node src/migrate.ts",
    "migrate:app": "cross-env NODE_ENV=development vite-node src/app-migrate.ts",
    "lint:migrations": "tsx --tsconfig tsconfig.json scripts/lint-migrations.ts",
    "bench:aggregate-projection": "vite-node scripts/bench-aggregate-projection.ts",
    "bench:translation-prompt": "vite-node scripts/bench-translation-prompt.ts",
    "bundle": "vite build",
    "start": "cross-env NODE_ENV=development nodemon --signal SIGKILL --watch src --ext ts,json --exec \"vite-node src/dev.ts\"",
    "start:debug": "cross-env NODE_ENV=development nodemon --signal SIGKILL --watch src --ext ts,json --exec \"node --inspect --import vite-node/register src/dev.ts\"",
    "start:cluster": "cross-env NODE_ENV=development nodemon --signal SIGKILL --watch src --ext ts,json --exec \"vite-node src/dev.ts -- --cluster --cluster_workers 2\"",
    "start:prod": "cross-env NODE_ENV=production node dist/src/main",
    "lint": "eslint src/**/*.ts --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prod": "cross-env NODE_ENV=production pm2-runtime start ecosystem.config.cjs",
    "prod:pm2": "cross-env NODE_ENV=production pm2 restart ecosystem.config.cjs",
    "prod:stop": "pm2 stop ecosystem.config.cjs",
    "prod:debug": "cross-env NODE_ENV=production nest start --debug --watch",
    "test": "NODE_ENV=development vitest",
    "test:watch": "NODE_ENV=development vitest -w",
    "test:live": "NODE_ENV=development RUN_LIVE_TESTS=1 vitest run translation-review-pipeline.live.e2e-spec.ts",
    "test:live:local": "NODE_ENV=development RUN_LIVE_TESTS=1 SMOKE_PROVIDER=openai-compatible vitest run translation-review-pipeline.live.e2e-spec.ts",
    "test:live:mix": "NODE_ENV=development RUN_LIVE_TESTS=1 SMOKE_TRANSLATOR_PROVIDER=openai-compatible SMOKE_REVIEWER_PROVIDER=openrouter SMOKE_REVIEWER_MODEL=openai/gpt-5.5 vitest run translation-review-pipeline.live.e2e-spec.ts",
    "test:live:deepseek-mix": "NODE_ENV=development RUN_LIVE_TESTS=1 SMOKE_REVIEWER_MODEL=openai/gpt-5.5 vitest run translation-review-pipeline.live.e2e-spec.ts",
    "docs": "npx @compodoc/compodoc -p tsconfig.json -s -d docs",
    "publish": "bump"
  },
  "bump": {
    "before": [
      "git pull --rebase",
      "pnpm i",
      "node scripts/bump-admin-version.js"
    ],
    "changelog": true
  },
