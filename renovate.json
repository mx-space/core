{
  "extends": [
    "config:base",
    ":automergePatch",
    ":automergeTypes",
    ":automergeTesters",
    ":automergeLinters",
    ":rebaseStalePrs"
  ],
  "packageRules": [
    {
      "updateTypes": [
        "major"
      ],
      "labels": [
        "UPDATE-MAJOR"
      ]
    },
    {
      "matchPackageNames": [
        "@earendil-works/pi-ai"
      ],
      "labels": [
        "requires-faux-and-live-tests"
      ],
      "rangeStrategy": "pin"
    }
  ],
  "ignoreDeps": [
    "vitest",
    "vite",
    "snakecase-keys"
  ],
  "enabled": true
}
